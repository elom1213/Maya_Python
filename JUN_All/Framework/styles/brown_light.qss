QWidget {
    background-color: #f5efe9;
    color: #3a3a3a;
    font-size: 12px;
}

QLabel {
    color: #3a3a3a;
    background: transparent;
}

QPushButton {
    background-color: #cbb79c;
    color: #3a3a3a;
    border: 1px solid #b39d80;
    padding: 8px;
    border-radius: 4px;
}

QPushButton:hover {
    background-color: #d8c6ad;
}

QPushButton:pressed {
    background-color: #bca588;
}

QLineEdit, QTextEdit, QPlainTextEdit, QListWidget, QSpinBox, QComboBox {
    background-color: #ffffff;
    color: #3a3a3a;
    border: 1px solid #b39d80;
    padding: 4px;
    border-radius: 3px;
}

QListWidget::item:selected {
    background-color: #b39d80;
    color: #ffffff;
}

QComboBox:hover {
    border: 1px solid #b39d80;
}

QCheckBox {
    color: #3a3a3a;
    background: transparent;
}

QCheckBox::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid #b39d80;
    border-radius: 3px;
    background-color: #ffffff;
}

QCheckBox::indicator:hover {
    border: 1px solid #b39d80;
}

QCheckBox::indicator:checked {
    background-color: #b39d80;
    border: 1px solid #b39d80;
}

QRadioButton {
    color: #3a3a3a;
    background-color: #ffffff;
    border: 1px solid #b39d80;
    border-radius: 4px;
    padding: 4px 8px;
    margin: 2px 0;
}

QRadioButton::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid #b39d80;
    border-radius: 7px;
    background-color: #ffffff;
}

QRadioButton::indicator:hover {
    border: 1px solid #b39d80;
}

QRadioButton::indicator:checked {
    background-color: #b39d80;
    border: 1px solid #b39d80;
}

QMenuBar {
    background-color: #f5efe9;
    color: #3a3a3a;
}

QMenuBar::item:selected {
    background-color: #b39d80;
}

QMenu {
    background-color: #f5efe9;
    color: #3a3a3a;
}

QMenu::item:selected {
    background-color: #b39d80;
}

QGroupBox {
    border: 1px solid #b39d80;
    margin-top: 10px;
    padding-top: 10px;
}

QGroupBox::title {
    color: #8a6f50;
}

/* --- QSpinBox up/down buttons: define sub-controls so the arrow
       buttons keep a clickable hit-area + arrow cursor once the QSpinBox
       border/padding above is styled (Qt drops native arrows otherwise). --- */
QSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 16px;
    background-color: #ffffff;
    border-left: 1px solid #b39d80;
    border-top-right-radius: 3px;
}

QSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 16px;
    background-color: #ffffff;
    border-left: 1px solid #b39d80;
    border-bottom-right-radius: 3px;
}

QSpinBox::up-button:hover, QSpinBox::down-button:hover {
    background-color: #b39d80;
}

QSpinBox::up-arrow {
    image: url(@STYLES@/sb_up_dark.png);
    width: 9px;
    height: 9px;
}

QSpinBox::down-arrow {
    image: url(@STYLES@/sb_down_dark.png);
    width: 9px;
    height: 9px;
}
